# Xray Cloud API credentials
# Generate these from Xray Global Settings > API Keys
XRAY_CLIENT_ID=your_client_id_here
XRAY_CLIENT_SECRET=your_client_secret_here

# Xray region endpoint (us, eu, au)
# us = https://xray.cloud.getxray.app
# eu = https://eu.xray.cloud.getxray.app
# au = https://au.xray.cloud.getxray.app
XRAY_REGION=us

# Default Jira project key for test creation
JIRA_PROJECT_KEY=YOUR_PROJECT_KEY
